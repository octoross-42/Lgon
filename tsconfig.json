{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "build",
    "rootDir": "src",
    "paths": {
	  "adapters/*": ["./src/adapters/*"],
      "application/*": ["./src/application/*"],
      "core/*": ["./src/core/*"],
      "infra/*": ["./src/infra/*"],
      "types/*": ["./src/types/*"],
      "messagingFlows/*": ["./src/messagingFlows/*"],
      "constants.js": ["./src/constants.ts"],
      "bootstrap.js": ["./src/bootstrap.ts"],
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "exclude": ["node_modules"],
  "include": ["src/**/*.ts"]
}
